# ---- Server ----
PORT=4000
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ---- Security ----
# Generate strong random values for production, e.g. `openssl rand -hex 32`
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_REFRESH_SECRET=change-me-too-another-long-random-string
JWT_EXPIRES_IN=7d
COOKIE_SECURE=false

# ---- MongoDB (leave blank to use the local JSON store fallback) ----
# e.g. mongodb+srv://user:pass@cluster0.xxxx.mongodb.net/
MONGODB_URI=
MONGODB_DB=wc2026_predictor

# ---- Redis cache (leave blank to use the in-memory cache fallback) ----
# e.g. redis://localhost:6379  or  rediss://:password@host:port
REDIS_URL=

# ---- Google OAuth 2.0 (leave blank to disable Google sign-in) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# ---- Live scores (TheSportsDB free/open API) ----
# "3" is the public free test key; register for your own for higher limits.
SPORTSDB_KEY=3
LIVE_CACHE_TTL_MS=30000

# ---- Scraping (fallback live-data source) ----
SCRAPE_SOURCE_URL=https://www.bbc.com/sport/football/world-cup/scores-fixtures
SCRAPE_CACHE_TTL_MS=60000
SCRAPE_USER_AGENT=WC26PredictorBot/1.0 (+contact@example.com)
