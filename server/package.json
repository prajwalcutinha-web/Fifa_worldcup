{
  "name": "wc26-predictor-server",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Secure Node.js backend for the WC26 Predictor League (auth, predictions, scoring, live-data scraping).",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "scrape": "node src/scripts/runScrape.js",
    "verify": "node src/scripts/verifyMongo.js"
  },
  "dependencies": {
    "axios": "1.7.9",
    "bcryptjs": "2.4.3",
    "cheerio": "1.0.0",
    "compression": "1.7.5",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "dotenv": "16.4.7",
    "express": "4.21.2",
    "express-rate-limit": "7.5.0",
    "helmet": "8.0.0",
    "ioredis": "5.4.2",
    "jsonwebtoken": "9.0.2",
    "mongoose": "8.9.5",
    "morgan": "1.10.0",
    "nanoid": "5.0.9",
    "zod": "3.24.1"
  }
}
