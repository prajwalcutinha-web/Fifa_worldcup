# ===== PRODUCTION ENV for worldcupboys.world =====
# Copy to `.env` on the server and fill in the real secret values.
# NEVER commit the filled-in .env.

PORT=5000
NODE_ENV=production

# Single-origin deploy: the Node app serves BOTH the API and the React frontend
# at the apex domain, so no API subdomain or cross-site CORS is needed.
CORS_ORIGINS=https://worldcupboys.world,https://www.worldcupboys.world
FRONTEND_URL=https://worldcupboys.world

# Security — generate with: openssl rand -hex 32
JWT_SECRET=<generate-strong-secret>
JWT_REFRESH_SECRET=<generate-another-strong-secret>
JWT_EXPIRES_IN=7d
# Required so session cookies are only sent over HTTPS in production.
COOKIE_SECURE=true

# MongoDB Atlas
MONGODB_URI=mongodb+srv://prajwalcutinha_db_user:<password>@cluster0.xlsniry.mongodb.net/wc2026_predictor
MONGODB_DB=wc2026_predictor

# Redis (optional; leave blank to use in-memory cache)
REDIS_URL=

# Google OAuth 2.0 — from Google Cloud Console.
# Authorized redirect URI must EXACTLY match (same origin as the app):
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>
GOOGLE_CALLBACK_URL=https://worldcupboys.world/api/auth/google/callback

# Live scores
SPORTSDB_KEY=3
LIVE_CACHE_TTL_MS=30000
